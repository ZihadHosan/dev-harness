    "arch:watch": "node harness/arch-serve.mjs"
  },
  "keywords": [
    "developer-tools",
    "ai",
    "claude",
    "llm",
    "architecture",
    "project-management",
    "cli",
    "planning",
    "productivity",
    "dx",
    "code-health",
    "agent"
  ],
  "author": "Zihad Hosan",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
