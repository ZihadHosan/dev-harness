{
  "name": "dev-harness",
  "version": "0.1.0",
  "description": "AI-native project harness — architecture map, planning board and health checks for any codebase",
  "type": "module",
  "bin": {
    "dev-harness": "./init.mjs"
  },
  "scripts": {
    "arch": "node harness/arch-map.mjs",
