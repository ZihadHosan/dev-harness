{
  "name": "dev-harness",
  "version": "0.1.0",
  "description": "AI-native project harness — architecture map, planning board and health checks for any codebase",
  "type": "module",
  "bin": {
    "dev-harness": "./init.mjs"
  },
  "scripts": {
    "arch":              "node harness/arch-map.mjs",
    "arch:check":        "node harness/arch-map.mjs --strict",
    "arch:watch":        "node harness/arch-serve.mjs",
    "harness:sync":      "node harness/sync.mjs",
    "harness:install":   "node harness/install.mjs",
    "harness:check":     "node harness/context-sync/hash-check.mjs",
    "harness:baseline":  "node harness/context-sync/hash-check.mjs --update",
    "harness:verify":    "node harness/context-sync/verify.mjs",
    "harness:lockstep":  "node harness/context-sync/lockstep.mjs",
    "harness:doctor":    "node harness/doctor.mjs"
  },
  "keywords": [
    "developer-tools",
    "ai",
    "claude",
    "llm",
    "architecture",
    "project-management",
    "cli",
    "planning",
    "productivity",
    "dx",
    "code-health",
    "agent"
  ],
  "author": "Zihad Hosan",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
