{
  "$comment": "Harness hook wiring for Claude Code. Copy to .claude/settings.json, or run `npm run harness:install` to merge into an existing one. These hooks make the agent harness DYNAMIC — see harness/README.md.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node harness/context-sync/hash-check.mjs --quiet"
          },
          {
            "type": "command",
            "command": "node harness/context-sync/verify.mjs --quiet"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node harness/context-sync/prompt-guard.mjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node harness/context-sync/edit-guard.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node harness/context-sync/hash-check.mjs --update"
          },
          {
            "type": "command",
            "command": "node harness/arch-map.mjs --quiet"
          }
        ]
      }
    ]
  }
}
